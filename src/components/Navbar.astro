---
// Importamos el componente interactivo de React
import FormModal from './FormModal.jsx';
---
<header class="sticky top-0 z-40 w-full border-b border-pink-100/50 bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    
<a href="/" class="flex items-center group">
  <img 
    src="/logo-doce-brisa.png" 
    alt="Doce Brisa Pasteleria" 
    class="h-14 w-auto object-contain transition-transform duration-300 group-hover:scale-105" 
  />
</a>

    <nav class="hidden md:flex items-center gap-8">
      <a href="/#inicio" class="text-sm font-medium text-slate-600 hover:text-pink-500 transition-colors">Inicio</a>
      <a href="/#catalogo" class="text-sm font-medium text-slate-600 hover:text-pink-500 transition-colors">Nuestro Catálogo</a>
    </nav>

    <div class="flex items-center gap-4">
      <FormModal client:load />
    </div>

  </div>
</header>