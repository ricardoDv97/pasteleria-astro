---
// Importamos el componente interactivo de React
import FormModal from './FormModal.jsx';
---
<header class="sticky top-0 z-40 w-full border-b border-pink-100/50 bg-white/80 backdrop-blur-md">
  {/* El contenedor principal debe tener 'relative' para que el logo absoluto se posicione respecto a él */}
  <div class="relative mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    
    {/* Contenedor del Logo Flotante */}
    <div class="absolute left-4 top-2 z-50">
      <a href="/" class="flex items-center group">
        <img 
          src="/logo.webp" 
          alt="Dulce Gracia Pasteleria" 
          {/* - h-28 y w-28 le dan un tamaño mayor a los h-20 del navbar para que sobresalga abajo.
            - drop-shadow le da una sombra suave para que resalte hermoso sobre el Hero.
          */}
          class="h-28 w-28 md:h-32 md:w-32 object-contain transition-transform duration-300 group-hover:scale-105 drop-shadow-md" 
        />
      </a>
    </div>

    {/* Dejamos un espacio invisible (spacer) a la izquierda en desktop para que el menú de navegación no colisione con el logo flotante */}
    <div class="w-28 md:w-32 block"></div>

    <nav class="hidden md:flex items-center gap-8">
      <a href="/#inicio" class="text-sm font-medium text-slate-600 hover:text-pink-500 transition-colors">Inicio</a>
      <a href="/#catalogo" class="text-sm font-medium text-slate-600 hover:text-pink-500 transition-colors">Nuestro Catálogo</a>
    </nav>

    <div class="flex items-center gap-4">
      <FormModal client:load />
    </div>

  </div>
</header>