---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
// Importamos los datos locales de los productos
import productos from '../data/productos.json';
---

<Layout title="Dulce Gracia | Tortas y Tartas de Diseño">
	<Navbar />

	<main class="bg-[#FFFDFB]">
		<section id="inicio" class="relative overflow-hidden bg-gradient-to-tr from-pink-50 via-amber-50/30 to-white py-12 px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl text-center">
				<span class="inline-flex items-center rounded-full bg-pink-50 px-3 py-1 text-sm font-medium text-pink-600 ring-1 ring-inset ring-pink-500/10 mb-3">
					Pastelería Artesanal & Frescura de Verano
				</span>
				<h1 class="text-4xl sm:text-6xl font-black tracking-tight text-slate-900 mb-4 leading-tight">
					hecho con amor, <br/>
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-rose-500">pensado para compartir</span>
				</h1>
				<p class="text-lg text-slate-600 max-w-2xl mx-auto mb-6">
					En <strong>Dulce Gracia</strong> transformamos tus ideas en piezas de azúcar únicas. Calidad premium con ingredientes seleccionados para que tus momentos brillen.
				</p>
			</div>
		</section>

		<section id="catalogo" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 border-t border-pink-50">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Nuestro Catálogo Exclusivo</h2>
				<p class="mt-3 text-lg text-slate-500">Artesanías dulces preparadas minuciosamente para ti.</p>
			</div>

			<div class="grid grid-cols-1 gap-y-10 gap-x-6 sm:grid-cols-2 lg:grid-cols-4 xl:gap-x-8">
				{productos.map((producto) => (
					<div class="group relative flex flex-col justify-between bg-white rounded-3xl p-4 shadow-sm hover:shadow-xl hover:shadow-pink-100/50 transition-all duration-300 border border-pink-50/50">
						<div>
							<div class="w-full h-48 overflow-hidden rounded-2xl bg-slate-100 group-hover:opacity-95 transition-opacity duration-300">
								<img 
									src={producto.imagen} 
									alt={producto.nombre} 
									class="w-full h-full object-cover object-center"
								/>
							</div>
							
							<div class="mt-4 flex justify-between items-start">
								<div>
									<span class="text-xs font-semibold uppercase tracking-wider text-pink-500">{producto.categoria}</span>
									<h3 class="text-lg font-bold text-slate-800 mt-0.5">{producto.nombre}</h3>
								</div>
							</div>
							<p class="mt-2 text-sm text-slate-500 line-clamp-3">{producto.descripcion}</p>
						</div>

						<div class="mt-5">
							<a
								href={`https://wa.me/543765380766?text=${encodeURIComponent(`¡Hola! Me gustaría consultar disponibilidad y presupuesto para el producto: ${producto.nombre}`)}`}
								target="_blank"
								rel="noopener noreferrer"
								class="w-full inline-flex items-center justify-center text-center bg-pink-50 text-pink-600 font-semibold text-sm px-4 py-2.5 rounded-xl hover:bg-pink-500 hover:text-white transition-all duration-200"
							>
								Consultar por WhatsApp 🟢
							</a>
						</div>
					</div>
				))}
			</div>
		</section>

		<section id="nosotros" class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 border-t border-pink-50/60">
			<div class="relative bg-gradient-to-br from-pink-50/30 via-white to-amber-50/20 rounded-3xl p-8 sm:p-12 border border-pink-100/40 shadow-sm text-center overflow-hidden">
				
				<div class="max-w-2xl mx-auto z-10 relative">
					<span class="text-xs font-bold uppercase tracking-widest text-pink-500">Conocé nuestra esencia</span>
					<h2 class="text-3xl font-extrabold text-slate-950 mt-2 mb-6 sm:text-4xl">Nuestra Historia & Compromiso</h2>
					
					<div class="text-slate-600 text-base sm:text-lg space-y-4 leading-relaxed">
						<p>
							En <strong class="text-pink-600">Dulce Gracia</strong> elaboramos tortas, tartas, lemon pie y dulces artesanales para acompañar tus celebraciones y momentos especiales. Utilizamos ingredientes de calidad y ponemos dedicación en cada preparación para ofrecerte sabor, frescura y una presentación cuidada hasta el último detalle.
						</p>
						<p class="font-medium text-slate-800 bg-white/60 backdrop-blur-sm p-4 rounded-2xl border border-pink-100/30 inline-block shadow-sm">
							💖 Cada creación está hecha con amor, inspirada en la gracia de Dios y pensada para endulzar tus momentos más importantes.
						</p>
					</div>
				</div>

				<div class="hidden md:block absolute right-4 top-1/2 -translate-y-1/2 w-44 lg:w-52 opacity-90 pointer-events-none z-20">
    <img 
        src="/animada.webp" 
        alt="Mascota Repostera Dulce Gracia" 
        class="w-full h-auto object-contain"
    />
</div>

				<div class="mt-8 flex flex-col items-center justify-center gap-2 relative z-10">
					<div class="flex items-center gap-1 text-amber-400 drop-shadow-sm">
						{[...Array(5)].map((_, i) => (
							<svg 
								class={`w-6 h-6 fill-current transition-transform duration-300 hover:scale-125`} 
								style={`animation-delay: ${i * 150}ms`}
								viewBox="0 0 24 24" 
								xmlns="http://www.w3.org/2000/svg"
							>
								<path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
							</svg>
						))}
					</div>
					<span class="text-xs font-semibold uppercase tracking-wider text-amber-600/80 mt-1">Calidad de Excelencia de 5 Estrellas</span>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>