---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
// Importamos los datos locales de los productos
import productos from '../data/productos.json';
---

<Layout title="Amanecer Pastelero | Tortas y Tartas de Diseño">
	<!-- Navegación superior -->
	<Navbar />

	<main class="bg-[#FFFDFB]">
		<!-- Hero Section -->
		<section id="inicio" class="relative overflow-hidden bg-gradient-to-tr from-pink-50 via-amber-50/30 to-white py-24 px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl text-center">
				<span class="inline-flex items-center rounded-full bg-pink-50 px-3 py-1 text-sm font-medium text-pink-600 ring-1 ring-inset ring-pink-500/10 mb-4">
					Pastelería Artesanal de Vanguardia
				</span>
				<h1 class="text-4xl sm:text-6xl font-black tracking-tight text-slate-900 mb-6 leading-tight">
					Diseños que cautivan, <br/>
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-rose-500">sabores que enamoran</span>
				</h1>
				<p class="text-lg text-slate-600 max-w-2xl mx-auto mb-10">
					En Amanecer Pastelero transformamos tus ideas en piezas de azúcar únicas. Calidad premium con ingredientes seleccionados para tus eventos en Posadas.
				</p>
			</div>
		</section>

		<!-- Catálogo Dinámico -->
		<section id="catalogo" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 border-t border-pink-50">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Nuestro Catálogo Exclusivo</h2>
				<p class="mt-3 text-lg text-slate-500">Artesanías dulces preparadas minuciosamente para ti.</p>
			</div>

			<!-- Grid de Tarjetas -->
			<div class="grid grid-cols-1 gap-y-10 gap-x-6 sm:grid-cols-2 lg:grid-cols-4 xl:gap-x-8">
				{productos.map((producto) => (
					<div class="group relative flex flex-col justify-between bg-white rounded-3xl p-4 shadow-sm hover:shadow-xl hover:shadow-pink-100/50 transition-all duration-300 border border-pink-50/50">
						<div>
							<!-- Contenedor de Imagen -->
							<div class="w-full h-48 overflow-hidden rounded-2xl bg-slate-100 group-hover:opacity-95 transition-opacity duration-300">
								<img 
									src={producto.imagen} 
									alt={producto.nombre} 
									class="w-full h-full object-cover object-center"
								/>
							</div>
							
							<!-- Detalles del Producto -->
							<div class="mt-4 flex justify-between items-start">
								<div>
									<span class="text-xs font-semibold uppercase tracking-wider text-pink-500">{producto.categoria}</span>
									<h3 class="text-lg font-bold text-slate-800 mt-0.5">{producto.nombre}</h3>
								</div>
							</div>
							<p class="mt-2 text-sm text-slate-500 line-clamp-3">{producto.descripcion}</p>
						</div>

						<!-- Botón de Acción a WhatsApp -->
						<div class="mt-5">
							<a
								href={`https://wa.me/543765380766?text=${encodeURIComponent(`¡Hola! Me gustaría consultar disponibilidad y presupuesto para el producto: ${producto.nombre}`)}`}
								target="_blank"
								rel="noopener noreferrer"
								class="w-full inline-flex items-center justify-center text-center bg-pink-50 text-pink-600 font-semibold text-sm px-4 py-2.5 rounded-xl hover:bg-pink-500 hover:text-white transition-all duration-200"
							>
								Consultar por WhatsApp 🟢
							</a>
						</div>
					</div>
				))}
			</div>
		</section>
	</main>

	<!-- Pie de página -->
	<Footer />
</Layout>